# =============================================================
# Copiloto Comercial Industrial — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# NUNCA subir .env.local a git (ya está en .gitignore)
# =============================================================

# --- Supabase ---
# URL del proyecto (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave publicable (Project Settings > API > publishable key)
# Es segura para el cliente; las reglas de RLS protegen los datos
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Clave service_role — SOLO para API routes del servidor, JAMÁS al cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# --- Anthropic (IA) ---
# console.anthropic.com > API Keys
# Solo se usa en API routes del servidor
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- OpenAI Whisper (transcripción de llamadas) ---
# platform.openai.com > API Keys
# Solo se usa en API routes del servidor
OPENAI_API_KEY=sk-proj-...

# --- Opcional: configuración ---
# URL pública de la app (para callbacks de auth)
NEXT_PUBLIC_APP_URL=http://localhost:3000
